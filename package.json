{
  "name": "next-latest-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "generate:types": "payload generate:types",
    "standalone-script": "tsx ./src/scripts/standalone-script.ts",
    "start:postgres": "docker compose -f docker-compose.yml --env-file .env.development up -d",
    "stop:postgres": "docker compose -f docker-compose.yml --env-file .env.development down",
    "nuke": "rm -r node_modules; rm -r pnpm-lock.yaml"
  },
  "engines": {
    "node": ">=18.19.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@payloadcms/db-mongodb": "3.0.0-beta.9",
    "@payloadcms/db-postgres": "3.0.0-beta.9",
    "@payloadcms/next": "3.0.0-beta.9",
    "@payloadcms/richtext-lexical": "3.0.0-beta.9",
    "@payloadcms/richtext-slate": "3.0.0-beta.9",
    "@payloadcms/ui": "3.0.0-beta.9",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@react-email/components": "^0.0.16",
    "@react-email/render": "^0.0.12",
    "cross-env": "^7.0.3",
    "lucide-react": "^0.372.0",
    "next": "14.3.0-canary.7",
    "payload": "3.0.0-beta.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-email": "^2.1.1",
    "react-hook-form": "^7.51.3",
    "sharp": "0.32.6",
    "sonner": "^1.4.41",
    "zod": "^3.22.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.25",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.1.0",
    "tsx": "^4.7.1",
    "@tailwindcss/aspect-ratio": "^0.4.x",
    "@tailwindcss/container-queries": "^0.1.x",
    "@types/bcryptjs": "^2.4.6",
    "@types/uuid": "^9.0.7",
    "autoprefixer": "^10",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "postcss": "^8",
    "prettier": "^3",
    "prettier-plugin-tailwindcss": "^0.5.x",
    "prisma": "^5.5.2",
    "tailwind-merge": "^1.14.0",
    "tailwindcss": "^3",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  },
  "packageManager": "pnpm@8.15.4+sha256.cea6d0bdf2de3a0549582da3983c70c92ffc577ff4410cbf190817ddc35137c2"
